        <body>
            <div type="bibliography">
                <listRelation>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS6819Mary"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS2481Bartholo"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS3915Eustathi"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS6902Matthew"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS1948Anne"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS5687Joachim"/>
                    <relation name="ecrm:P129_is_about" active="LIT7889Prayers" passive="PRS7049Michael"/>
                </listRelation>
            </div>
            <div type="edition">
                <note>The incipits of the textparts are taken from <ref type="mss" corresp="EMIP02337#a3"/>.</note>
                <div type="textpart" subtype="textsubunit" xml:id="Mary">
                    <label>Prayer for intercession of St Mary</label>
                    <ab>በጸሎታ፡ ወበስእለታ፡ ለእግዝእትነ፡ ማርያም፡ <abbr>ት</abbr><ex>ሣሀለነ፡</ex> <abbr>እ</abbr><ex>ግዚአ፡</ex> በትንብልናሃ፡ 
                        ወበንጽሐ፡ ሥጋሃ፡ ለእግዝእትነ፡ ማርያም፡ <abbr>ት</abbr><ex>ሣሀለነ፡</ex> <abbr>እ</abbr><ex>ግዚአ፡</ex>
                        <gap reason="ellipsis"/></ab>
                </div>
                <div type="textpart" subtype="textsubunit" xml:id="Bartholomew">
                    <label>Prayer for intercession of St Bartholomew</label>
                    <ab>በጸሎቱ፡ ወበስእለቱ፡ ወበስምዓ፡ ሞቱ፡ ለበርተ፡ ሎሜዎስ፡ ሐ<supplied reason="omitted" resp="CH">ዋ</supplied>ርያከ፡
                        <abbr>ት</abbr><ex>ሣሀለነ፡</ex> <abbr>እ</abbr><ex>ግዚአ፡</ex></ab>
                </div>
                <div type="textpart" subtype="textsubunit" xml:id="MatthewJames">
                    <label>Prayer for intercession of St Matthew the Evangelist and St James son of Zebedee</label>
                    <ab>በጸሎቶሙ፡ ወበስ<supplied reason="omitted" resp="CH">እ</supplied>ለቶሙ፡ ወበምትረተ፡ ርእሶሙ፡ ለማቲዎስ፡ ወንጌላዊ፡ 
                        ወለ<add place="above">ያ</add><supplied reason="omitted" resp="CH">ዕ</supplied>ቆብ፡ ወልደ፡ ዘብዴዎስ፡ 
                        <abbr>ት</abbr><ex>ሣሀለነ፡</ex> <abbr>እ</abbr><ex>ግዚአ፡</ex></ab>
                </div>
                <div type="textpart" subtype="textsubunit" xml:id="Eustathius">
                    <label>Prayer for intercession of St Eustathius</label>
                    <ab>በጸሎተ፡ ኤዎስጣቴዎስ፡ አቡነ፡ ድ<supplied reason="omitted" resp="CH">ንግ</supplied>ል፡</ab>
                </div>
                <div type="textpart" subtype="textsubunit" xml:id="AnneJoachim">
                    <label>Prayer for intercession of St Anne and St Joachin</label>
                    <ab>በጸሎተ፡ ሐና፡ ወኢያቄም፡ ዘወለድዋ፡ ለማርያም፡</ab>
                </div>
                <div type="textpart" subtype="textsubunit" xml:id="Mikael">
                    <ab>በጸሎተ፡ ሚካኤል፡</ab>
                </div>
            </div>
        </body>
    </text>
